{
  "manifest_version": 3,
  "name": "Dev Toolkit",
  "version": "1.2.0",
  "description": "API Tester \u00b7 Screen Recorder \u00b7 Bug Reporter",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.telegram.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Dev Toolkit"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "recorder.html",
        "recorder.js",
        "injected.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}